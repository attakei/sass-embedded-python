{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>aquaproj/aqua-renovate-config#2.13.0",
  ],
  "timezone": "Asia/Tokyo",
  "schedule": [
    // Run check at daytime on every weekend
    "* 9-21 * * 0,6"
  ],
  automerge: true,
  // Wait 3 days after a release before considering it; lets the broader
  // ecosystem catch hotfixes before our auto-merge picks the update up.
  minimumReleaseAge: "3 days",
  "packageRules": [
    // NOTE: Workflow's python version must be kept because it is minimum require-python version.
    {
      "matchFileNames": [".python-version"],
      "enabled": false,
    },
    {
      matchUpdateTypes: ["major"],
      automerge: false,
    },
  ],
}
